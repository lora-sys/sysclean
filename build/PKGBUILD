# Maintainer: lora-sys <3526039967@qq.com>
pkgname=sysclean
pkgver=0.1.0
pkgrel=1
pkgdesc="Global system cleanup and management TUI for Linux (services, Docker, Flatpak, disk, startup audit)"
arch=('any')
url="https://github.com/lora-sys/sysclean"
license=('MIT')
depends=('bash' 'whiptail' 'systemd' 'jq')
optdepends=(
  'docker: Docker container management'
  'flatpak: Flatpak app management'
  'sudo: system-level operations'
)
source=("sysclean-$pkgver.tar.gz")
sha256sums=('SKIP')

package() {
  cd "$srcdir/sysclean-$pkgver"
  install -Dm755 sysclean "$pkgdir/usr/bin/sysclean"
  install -Dm644 -t "$pkgdir/usr/share/sysclean/lib" lib/*.sh
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
  install -Dm644 README.zh-CN.md "$pkgdir/usr/share/doc/$pkgname/README.zh-CN.md"
  install -Dm644 CHANGELOG.md "$pkgdir/usr/share/doc/$pkgname/CHANGELOG.md"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
