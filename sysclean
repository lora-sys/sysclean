#!/usr/bin/env bash
# sysclean - system cleanup and management tool
# Usage: sysclean [options]
#        sysclean --scan
#        sysclean --cleanup <category> [--dry-run]

set -euo pipefail
VERSION="0.1.0"

# === Find lib dir ===
# Resolve absolute path of this script
if [ -n "${BASH_SOURCE[0]:-}" ] && [ "${BASH_SOURCE[0]}" != "bash" ] && [ "${BASH_SOURCE[0]}" != "-bash" ]; then
  SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
else
  SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || echo "$0")"
fi
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

# Search for lib in order of preference - must have ALL required files
REQUIRED_LIBS="common.sh ui.sh services.sh docker.sh flatpak.sh disk.sh startup.sh"
SYSCLEAN_LIB=""
for candidate in \
    "$HOME/.local/share/sysclean/lib" \
    "/usr/local/share/sysclean/lib" \
    "/usr/share/sysclean/lib" \
    "$SCRIPT_DIR/../share/sysclean/lib" \
    "$SCRIPT_DIR/lib" \
    "$(dirname "$SCRIPT_PATH")/../lib"; do
  if [ ! -d "$candidate" ]; then continue; fi
  # Check that ALL required libs exist (avoid partial installs)
  all_ok=1
  for lib in $REQUIRED_LIBS; do
    [ ! -f "$candidate/$lib" ] && { all_ok=0; break; }
  done
  if [ "$all_ok" = "1" ]; then
    SYSCLEAN_LIB="$candidate"
    break
  fi
done

if [ -z "$SYSCLEAN_LIB" ]; then
  echo "ERROR: cannot find sysclean lib dir (looked in standard locations)" >&2
  echo "  Script location: $SCRIPT_DIR" >&2
  exit 1
fi

# === Source libs ===
for f in common ui services docker flatpak disk startup; do
  if [ -f "$SYSCLEAN_LIB/$f.sh" ]; then
    source "$SYSCLEAN_LIB/$f.sh"
  else
    echo "ERROR: missing $f.sh (in: $SYSCLEAN_LIB)" >&2
    exit 1
  fi
done

# === CLI parsing ===
ACTION="menu"
TARGET=""
EXTRA_ARGS=()

usage() {
  cat << HELP
sysclean v$VERSION - 全局系统清理与管理工具

用法:
  sysclean                  启动交互式 TUI 菜单
  sysclean --scan           非交互式扫描，输出所有结果到 stdout
  sysclean --menu           启动 TUI（默认）
  sysclean --dry-run        TUI 模式下预览，不实际执行
  sysclean --yes            TUI 模式下默认 yes（跳过确认）
  sysclean --version        显示版本
  sysclean --help           显示此帮助

TUI 菜单分类:
  1. 系统服务管理 (systemd)
  2. Docker 管理
  3. Flatpak 管理
  4. 磁盘清理
  5. 启动项 & Shell RC
  6. 系统诊断

配置: ~/.config/sysclean/
  - state.json    白名单/黑名单/偏好
  - history.log   操作历史
  - sysclean.log  详细日志

HELP
}

while [ $# -gt 0 ]; do
  case "$1" in
    --scan)        ACTION="scan"; shift;;
    --menu)        ACTION="menu"; shift;;
    --dry-run|-n)  DRY_RUN=1; shift;;
    --yes|-y)      ASSUME_YES=1; shift;;
    --noninteract) NONINTERACTIVE=1; shift;;
    --version|-V)  echo "sysclean $VERSION"; exit 0;;
    --help|-h)     usage; exit 0;;
    *)             log_warn "Unknown flag: $1"; EXTRA_ARGS+=("$1"); shift;;
  esac
done

# === Scan mode ===
do_scan() {
  echo "═══════════════════════════════════════════════════════════"
  echo "  sysclean v$VERSION — System Scan"
  echo "═══════════════════════════════════════════════════════════"
  echo ""
  
  echo "─── 1. 系统资源 ───"
  df -h /home /var /tmp 2>/dev/null | grep -vE "^Filesystem|tmpfs"
  echo ""
  free -h 2>/dev/null | head -3
  echo ""
  
  echo "─── 2. 系统服务 (system) ───"
  local running_s; running_s=$(systemctl list-units --type=service --state=running --no-pager --no-legend 2>/dev/null | wc -l)
  local failed_s; failed_s=$(systemctl list-units --type=service --state=failed --no-pager --no-legend 2>/dev/null | wc -l)
  echo "  running: $running_s, failed: $failed_s"
  echo ""
  
  echo "─── 3. 用户服务 ───"
  local running_u; running_u=$(systemctl --user list-units --type=service --state=running --no-pager --no-legend 2>/dev/null | wc -l)
  local failed_u; failed_u=$(systemctl --user list-units --type=service --state=failed --no-pager --no-legend 2>/dev/null | wc -l)
  echo "  running: $running_u, failed: $failed_u"
  echo ""
  
  echo "─── 4. Docker ───"
  if has docker && docker info >/dev/null 2>&1; then
    docker system df
    echo ""
    echo "  containers: $(docker ps -a --format '{{.Names}}' 2>/dev/null | wc -l) (running: $(docker ps --format '{{.Names}}' 2>/dev/null | wc -l))"
    echo "  images:     $(docker images --format '{{.Repository}}' 2>/dev/null | wc -l)"
    echo "  volumes:    $(docker volume ls --format '{{.Name}}' 2>/dev/null | wc -l)"
    echo "  networks:   $(docker network ls --format '{{.Name}}' 2>/dev/null | tail -n +2 | wc -l)"
  else
    echo "  docker not available"
  fi
  echo ""
  
  echo "─── 5. Flatpak ───"
  if has flatpak; then
    echo "  apps:     $(flatpak list --app --columns=ref 2>/dev/null | wc -l)"
    echo "  runtimes: $(flatpak list --runtime --columns=ref 2>/dev/null | wc -l)"
  else
    echo "  flatpak not installed"
  fi
  echo ""
  
  echo "─── 6. 顶级磁盘占用 (top 15) ───"
  du -sh /home/lora/* 2>/dev/null | sort -hr | head -15 | awk '{printf "  %-10s %s\n", $1, $2}'
  echo ""
  
  echo "─── 7. 缓存大小 ───"
  for d in "$HOME/.cache" "$HOME/.local/share"; do
    [ -d "$d" ] && du -sh "$d" 2>/dev/null | awk '{printf "  %-10s %s\n", $1, $2}'
  done
  echo ""
  
  echo "─── 8. 回收站 ───"
  if [ -d "$HOME/.local/share/Trash" ]; then
    du -sh "$HOME/.local/share/Trash" 2>/dev/null || true
    ls -1 "$HOME/.local/share/Trash/files" 2>/dev/null | head -10 | sed 's/^/  • /' || true
  else
    echo "  (no trash directory)"
  fi
  echo ""
  
  echo "─── 9. 日志占用 ───"
  journalctl --disk-usage 2>/dev/null | head -1
  echo ""
  
  echo "─── 10. systemd 计时器 ───"
  systemctl list-timers --no-pager --no-legend 2>/dev/null | awk '{printf "  %-50s next: %s\n", $(NF-1), $1" "$2}'
  echo ""
  
  echo "─── 11. Shell RC 异常 ───"
  local issues; issues=$(scan_shell_rc_issues)
  if [ -z "$issues" ]; then
    echo "  ✓ no obvious issues"
  else
    echo "$issues" | sed 's/^/  /'
  fi
  echo ""
  
  echo "═══════════════════════════════════════════════════════════"
  echo "扫描完成。运行 'sysclean' 进入交互模式。"
}

# === Main menu ===
do_menu() {
  while true; do
    ui_clear
    
    # Quick health summary
    local disk_pct disk_avail
    read -r disk_pct disk_avail <<< "$(df -h /home 2>/dev/null | tail -1 | awk '{print $5, $4}')"
    local n_running_s; n_running_s=$(systemctl list-units --type=service --state=running --no-pager --no-legend 2>/dev/null | wc -l)
    local n_failed; n_failed=$(systemctl list-units --type=service --state=failed --no-pager --no-legend 2>/dev/null | wc -l)
    local docker_n; docker_n=$(docker ps -a --format '{{.Names}}' 2>/dev/null 2>/dev/null | wc -l)
    
    echo "╭─────────────────────────────────────────╮"
    echo "│  sysclean v$VERSION  (按 ESC 取消选择)   │"
    echo "│  磁盘: $disk_pct 已用, 可用 $disk_avail            │"
    echo "│  服务: $n_running_s 运行, $n_failed 失败              │"
    echo "╰─────────────────────────────────────────╯"
    echo ""
    
    ui_menu "sysclean 主菜单" 24 70 14 \
      "选择功能模块" \
      "1" "⚙️  服务管理 (systemd)" \
      "2" "🐳 Docker 管理" \
      "3" "📦 Flatpak 管理" \
      "4" "💾 磁盘清理" \
      "5" "🚀 启动项 & Shell RC" \
      "6" "🩺 系统诊断 & 扫描报告" \
      "7" "🧹 一键安全清理（保守）" \
      "8" "📜 查看操作历史" \
      "9" "⚙️  设置（白名单/黑名单）" \
      "0" "退出" \
     
    local choice="$REPLY"
    
    case "$choice" in
      1) manage_services ;;
      2) manage_docker ;;
      3) manage_flatpak ;;
      4) manage_disk ;;
      5) manage_startup ;;
      6) do_scan; ui_info "扫描完成" ;;
      7) _safe_auto_cleanup ;;
      8) _show_history ;;
      9) _settings ;;
      0|"") 
        log_ok "退出"
        exit 0
        ;;
    esac
  done
}

# === Settings ===
_settings() {
  while true; do
    ui_clear
    echo "设置"
    echo ""
    echo "配置文件: $SYSCLEAN_STATE"
    cat "$SYSCLEAN_STATE" 2>/dev/null | jq . 2>/dev/null || cat "$SYSCLEAN_STATE"
    echo ""
    
    ui_menu "设置" 14 70 5 \
      "操作" \
      "1" "查看白名单" \
      "2" "添加服务到白名单（永不提示停止）" \
      "3" "重置所有配置" \
      "0" "返回" \
     
    local c="$REPLY"
    case "$c" in
      1) ui_msg "$(jq -r '.whitelist[]?' "$SYSCLEAN_STATE" 2>/dev/null)" 18 60 ;;
      2)
        local svc; svc=$(ui_input "服务名 (e.g. bluetooth)" "")
        if [ -n "$svc" ]; then
          local tmp=$(mktemp)
          jq --arg s "$svc" '.whitelist += [$s] | .whitelist |= unique' "$SYSCLEAN_STATE" > "$tmp"
          mv "$tmp" "$SYSCLEAN_STATE"
          ui_info "已添加 $svc 到白名单"
        fi
        ;;
      3) if ui_yesno "重置所有 sysclean 配置?"; then
           rm -f "$SYSCLEAN_STATE"
           state_init
           ui_info "已重置"
         fi ;;
      0|"") return ;;
    esac
  done
}

# === History viewer ===
_show_history() {
  if [ -f "$SYSCLEAN_HISTORY" ]; then
    tail -50 "$SYSCLEAN_HISTORY" > /tmp/h.txt
    ui_msg "$(cat /tmp/h.txt)" 30 100
  else
    ui_info "暂无操作历史"
  fi
}

# === Main dispatch ===
case "$ACTION" in
  scan)  do_scan ;;
  menu)  do_menu ;;
  *)     usage; exit 1 ;;
esac
